  "item": [
    {
      "name": "GET All Posts",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Status Code\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Response time\r",
              "pm.test(\"Response time is less than 1000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});\r",
              "\r",
              "// JSON format\r",
              "pm.test(\"Response is JSON\", function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "// Response is array\r",
              "pm.test(\"Response is an array\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "// Array is not empty\r",
              "pm.test(\"Posts array is not empty\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "// Required fields\r",
              "pm.test(\"First post contains required fields\", function () {\r",
              "    const first = pm.response.json()[0];\r",
              "\r",
              "    pm.expect(first).to.have.property(\"userId\");\r",
              "    pm.expect(first).to.have.property(\"id\");\r",
              "    pm.expect(first).to.have.property(\"title\");\r",
              "    pm.expect(first).to.have.property(\"body\");\r",
              "});\r",
              "\r",
              "// ID is number\r",
              "pm.test(\"ID is numeric\", function () {\r",
              "    const first = pm.response.json()[0];\r",
              "    pm.expect(first.id).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "// Title is not empty\r",
              "pm.test(\"Title is not empty\", function () {\r",
              "    const first = pm.response.json()[0];\r",
              "    pm.expect(first.title).to.not.be.empty;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://jsonplaceholder.typicode.com/posts",
